[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    *.egg-info
ignore =
    # E203: whitespace before ':' (konflik dengan Black formatter)
    E203,
    # W503: line break before binary operator (konflik dengan Black)
    W503
per-file-ignores =
    # File __init__.py boleh punya unused import (untuk re-export)
    __init__.py: F401
