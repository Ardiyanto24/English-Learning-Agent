# ================================================
# ENGLISH LEARNING AGENT — Environment Variables
# ================================================
# Copy file ini menjadi .env dan isi nilai-nilainya
# JANGAN commit file .env ke repository!

# Anthropic API Key — untuk Claude Haiku & Sonnet
# Dapatkan di: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key — untuk Whisper STT dan TTS
# Dapatkan di: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Path ke file SQLite database
DATABASE_PATH=./english_agent.db

# Path ke ChromaDB vector store
CHROMA_DB_PATH=./vector_store/chroma_db
